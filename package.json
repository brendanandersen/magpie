{
  "name": "magpie",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Procedurally generate a plausible Indo-European-descended language from a seed, then translate English into it.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "inspect": "tsx scripts/inspect-schema.ts",
    "build-data": "tsx scripts/build-data.ts",
    "build-reflexes": "tsx scripts/build-reflexes.ts",
    "generate": "tsx scripts/generate.ts",
    "translate": "tsx scripts/translate.ts",
    "server": "tsx watch src/server/server.ts",
    "web": "vite",
    "web:build": "vite build",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:server\" \"npm:web\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.1.3-alpha.7",
    "@fastify/cors": "^11.3.0",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "fastify": "^5.10.0",
    "fflate": "^0.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
